      <rpointer_file>rpointer.unset</rpointer_file>
      <rpointer_content>unset</rpointer_content>
    </rpointer>
    <test_file_names>
      <tfile disposition="move">casename.dart.e.pop_preassim_priorinf_mean.1976-01-01-00000.nc</tfile>
