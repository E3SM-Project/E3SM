    <rest_file_extension>rh\d*</rest_file_extension>
    <hist_file_extension>h\d*</hist_file_extension>
    <rest_history_varname>unset</rest_history_varname>
    <rpointer>
      <rpointer_file>rpointer.rof$NINST_STRING</rpointer_file>
