#!/bin/bash
# FME (Full Model Emulation) online output processing testmod
#
# Production configuration for ACE/Samudra coupled model emulation training
# data generation. Enables online horizontal remapping, vertical coarsening,
# derived diagnostics, and column-integrated fields.
#
# Output frequencies:
#   EAM:     6-hourly (averaged and instantaneous)
#   MPAS-O:  daily (analysis member streams, configurable in Registry)
#   MPAS-SI: daily (analysis member stream)
#
# ---------------------------------------------------------------------------
# Map file generation (run once per grid combination, outside the case):
#
# Maps for ne30pg2_r05_IcoswISC30E3r5 -> shifted Gaussian 1-degree (180x360)
# are stored at: /pscratch/sd/m/mahf708/fme_maps/
#
# To regenerate them:
#
#   OUTDIR=/pscratch/sd/m/mahf708/fme_maps
#   mkdir -p $OUTDIR && cd $OUTDIR
#
#   # 1. Generate Gaussian 180x360 grid
#   ncremap -g ncremap_gaussian_grid_180_by_360.nc -G latlon=180,360#lat_typ=gss
#
#   # 2. Shift by 0.5 deg in longitude to match offline FV3-side grid
#   python3 - <<'PYEOF'
#   import netCDF4 as nc, shutil
#   shutil.copy2("ncremap_gaussian_grid_180_by_360.nc",
#                "ncremap_shifted_gaussian_grid_180_by_360.nc")
#   with nc.Dataset("ncremap_shifted_gaussian_grid_180_by_360.nc", "r+") as ds:
#       ds["grid_center_lon"][:] += 0.5
#       ds["grid_corner_lon"][:] += 0.5
#   PYEOF
#
#   # 3. Generate remapping weights for each source grid
#   GAUSS=$OUTDIR/ncremap_shifted_gaussian_grid_180_by_360.nc
#
#   # EAM (ne30pg2); ATM_GRID xmlquery returns ne30np4.pg2, normalized to ne30pg2
#   ncremap \
#     -s /global/cfs/cdirs/e3sm/inputdata/share/meshes/homme/ne30pg2_scrip_20200209.nc \
#     -g $GAUSS \
#     -m $OUTDIR/map_ne30pg2_to_gaussian_180by360_shifted.nc
#
#   # ELM and MOSART (r05 = 0.5x0.5 regular lat-lon)
#   ncremap \
#     -s /global/cfs/cdirs/e3sm/inputdata/lnd/clm2/mappingdata/grids/SCRIPgrid_0.5x0.5_nomask_c110308.nc \
#     -g $GAUSS \
#     -m $OUTDIR/map_r05_to_gaussian_180by360_shifted.nc
#
#   # MPAS-O and MPAS-SI (IcoswISC30E3r5 unstructured mesh)
#   ncremap \
#     -s /global/cfs/cdirs/e3sm/inputdata/ocn/mpas-o/IcoswISC30E3r5/ocean.IcoswISC30E3r5.mask.scrip.20231120.nc \
#     -g $GAUSS \
#     -m $OUTDIR/map_IcoswISC30E3r5_to_gaussian_180by360_shifted.nc
#
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Detect map files for this case's resolution
# ---------------------------------------------------------------------------
FME_MAPS_DIR=/pscratch/sd/m/mahf708/fme_maps

# Read grid names from the case XML
ATM_GRID=$(./xmlquery --value ATM_GRID)
OCN_GRID=$(./xmlquery --value OCN_GRID)

# Normalize ATM_GRID: CIME reports ne30np4.pg2; map files use ne30pg2 convention.
# Rule: strip npN. (e.g. np4.) from the middle of the name.
ATM_GRID_NORM=$(echo "$ATM_GRID" | sed 's/np[0-9]*\.//')

EAM_MAP="${FME_MAPS_DIR}/map_${ATM_GRID_NORM}_to_gaussian_180by360_shifted.nc"
OCN_MAP="${FME_MAPS_DIR}/map_${OCN_GRID}_to_gaussian_180by360_shifted.nc"

echo "FME map detection:"
echo "  ATM_GRID=${ATM_GRID} -> normalized: ${ATM_GRID_NORM}"
echo "  OCN_GRID=${OCN_GRID}"
echo "  EAM map : ${EAM_MAP} $([ -f "${EAM_MAP}" ] && echo '[found]' || echo '[NOT FOUND - remap disabled]')"
echo "  OCN map : ${OCN_MAP} $([ -f "${OCN_MAP}" ] && echo '[found]' || echo '[NOT FOUND - remap disabled]')"

# ---------------------------------------------------------------------------
# EAM namelist
# ---------------------------------------------------------------------------
cat >> user_nl_eam << 'EOF'
! FME (Full Model Emulation) online output processing -- EAM
!
! Production configuration for ACE/Samudra training data generation.
!
! Vertical coarsening uses EAM L80 interface pressures matching the ACE
! offline coarsening indices [0,25,38,46,52,56,61,69,80] (see:
! github.com/ai2cm/ace/blob/exp/e3sm/scripts/data_process/configs/
!   e3smv3-coupled-atm-1deg.yaml).
! Derived from hyai/hybi in eami_mam4_Linoz_ne30np4_L80_c20231010.nc.

empty_htapes = .true.
avgflag_pertape = 'I'
nhtfrq = -6
mfilt  = 4

! Derived fields (computed at full resolution before vcoarsen)
! STW -> specific_total_water in ACE naming
derived_fld_defs = 'STW=Q+CLDICE+CLDLIQ+RAINQM'

! Vertical coarsening: 8 pressure layers matching ACE L80 coarsening.
! Interface pressures (Pa) from L80 hyai/hybi at indices [0,25,38,46,52,56,61,69,80]:
!   0: 10.0 Pa,  25: 4803.8 Pa,  38: 13913.1 Pa,  46: 26856.3 Pa,
!  52: 43998.3 Pa, 56: 59659.7 Pa, 61: 76854.2 Pa, 69: 90711.8 Pa, 80: 101325.0 Pa
vcoarsen_pbounds = 10.0, 4803.81, 13913.06, 26856.34,
                   43998.31, 59659.67, 76854.15, 90711.83, 101325.0
vcoarsen_avg_flds = 'T','U','V','STW'

! Tape 1: 6-hourly mixed instantaneous/averaged.
! Default is instantaneous; fields with :A suffix are time-averaged.
! DTENDTTW is the dynamics-only tendency of column-integrated total water
! (= tendency_of_total_water_path_due_to_advection in ACE naming).
! It captures the change between end-of-previous-physics and start-of-current-physics,
! spanning exactly the dynamics step. Native EAM diagnostic in cam_diagnostics.F90.
fincl1 = 'SOLIN:A', 'PHIS',
          'LANDFRAC', 'OCNFRAC', 'ICEFRAC',
          'PS', 'TS',
          'T_0','T_1','T_2','T_3','T_4','T_5','T_6','T_7',
          'STW_0', 'STW_1','STW_2','STW_3','STW_4','STW_5','STW_6','STW_7',
          'U_0','U_1','U_2','U_3','U_4','U_5','U_6','U_7',
          'V_0','V_1','V_2','V_3','V_4','V_5','V_6','V_7',
          'FLUT:A', 'FSUTOA:A', 'FLDS:A', 'FLUS:A', 'FSDS:A', 'FSUS:A',
          'LHFLX:A','SHFLX:A',
          'TAUX:A', 'TAUY:A',
          'PRECT:A',
          'DTENDTTW'

EOF

if [ -f "${EAM_MAP}" ]; then
    cat >> user_nl_eam << EOF
! Horizontal remapping to shifted Gaussian 180x360
horiz_remap_file(1) = '${EAM_MAP}'
EOF
fi

# ---------------------------------------------------------------------------
# ELM namelist: stub for now
# ---------------------------------------------------------------------------
cat >> user_nl_elm << 'EOF'
hist_empty_htapes = .true.

EOF

# ---------------------------------------------------------------------------
# MOSART namelist: stub for now
# ---------------------------------------------------------------------------
cat >> user_nl_mosart << 'EOF'

EOF

# ---------------------------------------------------------------------------
# MPAS-Ocean namelist
# ---------------------------------------------------------------------------
cat >> user_nl_mpaso << 'EOF'
!----------------------------------------------------------------------------------
! FME online output -- MPAS-Ocean
!
! ACE needs: sst, ssh (zos), and depth-coarsened temperature (thetao),
! salinity (so), velocityZonal (uo), velocityMeridional (vo) at 19 layers.
! 5-daily compute interval to match legacy timeSeriesStatsCustom averaging.
!----------------------------------------------------------------------------------

config_AM_fmeDepthCoarsening_enable = .true.
config_AM_fmeDepthCoarsening_compute_interval = '00-00-05_00:00:00'
! 19 depth layers matching ACE ocean interface levels
config_AM_fmeDepthCoarsening_depth_bounds = '0,20,30,40,50,80,110,140,170,230,410,530,1020,1080,1720,1980,2820,3380,4620,6380'
config_AM_fmeDepthCoarsening_fields = 'temperature,salinity,velocityZonal,velocityMeridional'

config_AM_fmeDerivedFields_enable = .true.
config_AM_fmeDerivedFields_compute_interval = '00-00-05_00:00:00'
EOF

if [ -f "${OCN_MAP}" ]; then
    cat >> user_nl_mpaso << EOF
config_AM_fmeDepthCoarsening_output_stream = 'none'
config_AM_fmeDepthCoarsening_horiz_remap_file = '${OCN_MAP}'
config_AM_fmeDerivedFields_output_stream = 'none'
config_AM_fmeDerivedFields_horiz_remap_file = '${OCN_MAP}'
EOF
fi

# ---------------------------------------------------------------------------
# MPAS-SeaIce namelist
# ---------------------------------------------------------------------------
cat >> user_nl_mpassi << 'EOF'
!----------------------------------------------------------------------------------
! FME online output -- MPAS-Sea-Ice
!
! ACE needs: iceAreaTotal (ocean_sea_ice_fraction), iceVolumeTotal (sea_ice_volume).
! 5-daily compute interval to match legacy.
!----------------------------------------------------------------------------------

config_AM_fmeSeaiceDerivedFields_enable = .true.
config_AM_fmeSeaiceDerivedFields_compute_interval = '00-00-05_00:00:00'
EOF

if [ -f "${OCN_MAP}" ]; then
    cat >> user_nl_mpassi << EOF
config_AM_fmeSeaiceDerivedFields_output_stream = 'none'
config_AM_fmeSeaiceDerivedFields_horiz_remap_file = '${OCN_MAP}'
EOF
fi
