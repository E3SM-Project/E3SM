#!/bin/bash
# FME (Full Model Emulation) online output processing testmod
#
# Production configuration for ACE/Samudra coupled model emulation training
# data generation. Enables online horizontal remapping, vertical coarsening,
# derived diagnostics, and column-integrated fields.
#
# ---------------------------------------------------------------------------
# Runtime-configurable parameters (override via environment variables)
# ---------------------------------------------------------------------------
# EAM output frequency in hours (negative = hours in EAM convention)
FME_EAM_OUTPUT_HOURS=${FME_EAM_OUTPUT_HOURS:-6}
# EAM averaging flag: 'I' = instantaneous (default), fluxes use per-field :A
FME_EAM_AVGFLAG=${FME_EAM_AVGFLAG:-I}
# EAM file rotation policy. With 'one_month', files are rotated exactly at
# calendar-month boundaries (28-31 days x 4 records/file, depending on month)
# regardless of mfilt. Names are %y-%m.nc. Set FME_EAM_STORAGE=num_snapshots
# (and FME_EAM_MFILT to a finite value) for legacy mfilt-based rotation.
# Other valid values: 'one_year' (one file per calendar year, ~22 GB each).
FME_EAM_STORAGE=${FME_EAM_STORAGE:-one_month}
# mfilt is overridden by calendar rotation when FME_EAM_STORAGE != num_snapshots,
# so it just acts as an upper safety bound. 1500 > any month-record-count (124 max).
FME_EAM_MFILT=${FME_EAM_MFILT:-1500}
# MPAS compute/output interval (MPAS time interval string)
FME_MPAS_INTERVAL=${FME_MPAS_INTERVAL:-00-00-01_00:00:00}
# Directory containing the gaussian-180x360 SCRIP map files. Defaults to
# $DIN_LOC_ROOT/fme so the maps are managed by CIME's inputdata machinery
# (auto-fetched from the E3SM inputdata server at
# https://web.lcrc.anl.gov/public/e3sm/inputdata/fme/ on cache miss).
# Override only if you keep maps in a non-DIN_LOC_ROOT location.
FME_MAPS_DIR=${FME_MAPS_DIR:-$(./xmlquery --value DIN_LOC_ROOT)/fme}

echo "FME output configuration:"
echo "  EAM: ${FME_EAM_OUTPUT_HOURS}-hourly, avgflag=${FME_EAM_AVGFLAG}, mfilt=${FME_EAM_MFILT}, storage=${FME_EAM_STORAGE}"
echo "  MPAS: interval=${FME_MPAS_INTERVAL}"
#
# ---------------------------------------------------------------------------
# Map file generation (run once per grid combination, outside the case):
#
# Maps for ne30pg2_r05_IcoswISC30E3r5 -> shifted Gaussian 1-degree (180x360)
# are stored at: /pscratch/sd/m/mahf708/fme_maps/
#
# To regenerate them:
#
#   OUTDIR=/pscratch/sd/m/mahf708/fme_maps
#   mkdir -p $OUTDIR && cd $OUTDIR
#
#   # 1. Generate Gaussian 180x360 grid
#   ncremap -g ncremap_gaussian_grid_180_by_360.nc -G latlon=180,360#lat_typ=gss
#
#   # 2. Shift by 0.5 deg in longitude to match offline FV3-side grid
#   python3 - <<'PYEOF'
#   import netCDF4 as nc, shutil
#   shutil.copy2("ncremap_gaussian_grid_180_by_360.nc",
#                "ncremap_shifted_gaussian_grid_180_by_360.nc")
#   with nc.Dataset("ncremap_shifted_gaussian_grid_180_by_360.nc", "r+") as ds:
#       ds["grid_center_lon"][:] += 0.5
#       ds["grid_corner_lon"][:] += 0.5
#   PYEOF
#
#   # 3. Generate remapping weights for each source grid
#   GAUSS=$OUTDIR/ncremap_shifted_gaussian_grid_180_by_360.nc
#
#   # EAM (ne30pg2); ATM_GRID xmlquery returns ne30np4.pg2, normalized to ne30pg2
#   ncremap \
#     -s /global/cfs/cdirs/e3sm/inputdata/share/meshes/homme/ne30pg2_scrip_20200209.nc \
#     -g $GAUSS \
#     -m $OUTDIR/map_ne30pg2_to_gaussian_180by360_shifted.nc
#
#   # ELM and MOSART (r05 = 0.5x0.5 regular lat-lon)
#   ncremap \
#     -s /global/cfs/cdirs/e3sm/inputdata/lnd/clm2/mappingdata/grids/SCRIPgrid_0.5x0.5_nomask_c110308.nc \
#     -g $GAUSS \
#     -m $OUTDIR/map_r05_to_gaussian_180by360_shifted.nc
#
#   # MPAS-O and MPAS-SI (IcoswISC30E3r5 unstructured mesh)
#   ncremap \
#     -s /global/cfs/cdirs/e3sm/inputdata/ocn/mpas-o/IcoswISC30E3r5/ocean.IcoswISC30E3r5.mask.scrip.20231120.nc \
#     -g $GAUSS \
#     -m $OUTDIR/map_IcoswISC30E3r5_to_gaussian_180by360_shifted.nc
#
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Detect map files for this case's resolution
# ---------------------------------------------------------------------------

# Read grid names from the case XML
ATM_GRID=$(./xmlquery --value ATM_GRID)
OCN_GRID=$(./xmlquery --value OCN_GRID)

# Normalize ATM_GRID: CIME reports ne30np4.pg2; map files use ne30pg2 convention.
# Rule: strip npN. (e.g. np4.) from the middle of the name.
ATM_GRID_NORM=$(echo "$ATM_GRID" | sed 's/np[0-9]*\.//')

EAM_MAP="${FME_MAPS_DIR}/map_${ATM_GRID_NORM}_to_gaussian_180by360_shifted.nc"
OCN_MAP="${FME_MAPS_DIR}/map_${OCN_GRID}_to_gaussian_180by360_shifted.nc"

echo "FME map detection:"
echo "  ATM_GRID=${ATM_GRID} -> normalized: ${ATM_GRID_NORM}"
echo "  OCN_GRID=${OCN_GRID}"
echo "  EAM map : ${EAM_MAP} $([ -f "${EAM_MAP}" ] && echo '[cached]' || echo '[will be staged by check_input_data]')"
echo "  OCN map : ${OCN_MAP} $([ -f "${OCN_MAP}" ] && echo '[cached]' || echo '[will be staged by check_input_data]')"

# ---------------------------------------------------------------------------
# Register maps with CIME's inputdata machinery
# ---------------------------------------------------------------------------
# A dedicated Buildconf/fme.input_data_list file (rather than appending to
# cpl.input_data_list) avoids being clobbered by component buildnmls. CIME's
# check_input_data globs Buildconf/*.input_data_list, so this file is read by
# `./check_input_data --download`, which is invoked implicitly by case.submit
# and pulls any missing entries from the configured inputdata server.
mkdir -p Buildconf
cat > Buildconf/fme.input_data_list << EOF
fme_map_eam = ${EAM_MAP}
fme_map_ocn = ${OCN_MAP}
EOF

# ---------------------------------------------------------------------------
# EAM namelist
# ---------------------------------------------------------------------------
cat >> user_nl_eam << EOF
! FME (Full Model Emulation) online output processing -- EAM
!
! Production configuration for ACE/Samudra training data generation.
!
! Vertical coarsening by level index ranges, dp-weighted within each range.
! ACE L80 coarsening indices (0-based level boundaries, 8 output layers):
!   layer 0: levels [0, 25)    -- upper stratosphere/mesosphere
!   layer 1: levels [25, 38)   -- lower stratosphere
!   layer 2: levels [38, 46)   -- tropopause region
!   layer 3: levels [46, 52)   -- upper troposphere
!   layer 4: levels [52, 56)   -- mid troposphere
!   layer 5: levels [56, 61)   -- lower-mid troposphere
!   layer 6: levels [61, 69)   -- lower troposphere
!   layer 7: levels [69, 80)   -- boundary layer
! (see: github.com/ai2cm/ace/blob/exp/e3sm/scripts/data_process/configs/
!   e3smv3-coupled-atm-1deg.yaml)

empty_htapes = .true.
avgflag_pertape = '${FME_EAM_AVGFLAG}'
nhtfrq = -${FME_EAM_OUTPUT_HOURS}
mfilt  = ${FME_EAM_MFILT}
! Calendar-aligned file rotation (EAMxx-style; one_month = files named %y-%m.nc).
hist_file_storage_type = '${FME_EAM_STORAGE}'

! Derived fields (computed at full resolution before vcoarsen).
! STW -> specific_total_water in ACE naming.
!
! NOTE: eam_derived's validator only accepts state vars / constituents /
! pbuf fields / earlier derived fields (validate_field_name in
! eam_derived.F90:801). PRECSC/PRECSL are addfld-only diagnostics with
! no state/pbuf backing, so PRECST = PRECSC+PRECSL was added directly
! via addfld/outfld in cam_diagnostics.F90 instead -- 'PRECST:A' in
! fincl1 below references that native field, NOT a derived expression.
derived_fld_defs = 'STW=Q+CLDICE+CLDLIQ+RAINQM'

! Vertical coarsening: 8 dp-weighted layers by level index boundaries.
! 9 boundaries define 8 layers (0-based EAM level indices, top to bottom).
vcoarsen_level_bounds = 0, 25, 38, 46, 52, 56, 61, 69, 80
vcoarsen_avg_flds = 'T','U','V','STW','Q'

! Height-above-surface linear interpolation (m AGL) for ACE 2 m / 10 m fields.
! state%zm is height-above-surface at level midpoints; targets below the
! lowest midpoint collapse to the lowest level (no extrapolation).
vcoarsen_select_heights = 2.0, 10.0
vcoarsen_select_height_flds = 'T','U','V','STW','Q'

! Tape 1: ${FME_EAM_OUTPUT_HOURS}-hourly output.
! State variables are instantaneous; fluxes/tendencies use :A (time-averaged).
! 10 m wind speed and direction are derived offline from U_at_z10 and V_at_z10.
! Q is vcoarsened to 8 layers (Q_0..Q_7) like the other state fields, plus
! Q_at_z2 from the height-interp path; QREFHT is the standard CAM 2 m
! specific humidity diagnostic (kept for cross-comparison with Q_at_z2).
fincl1 = 'SOLIN:A', 'PHIS',
          'LANDFRAC', 'OCNFRAC', 'ICEFRAC',
          'PS', 'TS',
          'T_0','T_1','T_2','T_3','T_4','T_5','T_6','T_7',
          'STW_0', 'STW_1','STW_2','STW_3','STW_4','STW_5','STW_6','STW_7',
          'U_0','U_1','U_2','U_3','U_4','U_5','U_6','U_7',
          'V_0','V_1','V_2','V_3','V_4','V_5','V_6','V_7',
          'Q_0','Q_1','Q_2','Q_3','Q_4','Q_5','Q_6','Q_7',
          'T_at_z2', 'STW_at_z2','Q_at_z2',
          'U_at_z10', 'V_at_z10',
          'TREFHT', 'QREFHT',
          'FLUT:A', 'FLNT:A', 'FSNTOA:A', 'FSUTOA:A',
          'FLDS:A', 'FLUS:A', 'FSDS:A', 'FSUS:A', 'FSNS:A', 'FLNS:A',
          'LHFLX:A','SHFLX:A',
          'TAUX:A', 'TAUY:A',
          'PRECT:A', 'PRECST:A',
          'DTENDTTW:A'

EOF

cat >> user_nl_eam << EOF
! Horizontal remapping to shifted Gaussian 180x360.
! Staging is the responsibility of CIME's check_input_data via
! Buildconf/fme.input_data_list (registered earlier in this script).
horiz_remap_file(1) = '${EAM_MAP}'
EOF

# ---------------------------------------------------------------------------
# ELM namelist: stub for now
# ---------------------------------------------------------------------------
cat >> user_nl_elm << 'EOF'
hist_empty_htapes = .true.

EOF

# ---------------------------------------------------------------------------
# MOSART namelist: stub for now
# ---------------------------------------------------------------------------
cat >> user_nl_mosart << 'EOF'

EOF

# ---------------------------------------------------------------------------
# MPAS-Ocean namelist
# ---------------------------------------------------------------------------
cat >> user_nl_mpaso << EOF
!----------------------------------------------------------------------------------
! FME online output -- MPAS-Ocean
!
! ACE needs: sst, ssh (zos), and depth-coarsened temperature (thetao),
! salinity (so), velocityZonal (uo), velocityMeridional (vo) at 19 layers.
!----------------------------------------------------------------------------------

config_AM_fmeDepthCoarsening_enable = .true.
config_AM_fmeDepthCoarsening_compute_interval = 'dt'
! compute_on_startup=.false. is REQUIRED for warm-restart BFB.
!
! compute_on_startup runs the AM compute exactly once at MPAS_NOW
! before timestepping. For a cold start MPAS_NOW = start_time;
! for a warm restart MPAS_NOW = restart_time. With time_averaging
! enabled, the startup compute pushes one sample into the
! accumulator at that wall-clock instant — sample(start_time) on
! cold runs, sample(restart_time) on warm runs.
!
! Phase-1 of an ERS test does cold + write-restart-mid-run + keep-running.
! Phase-2 reads the restart and continues. The daily-average window
! that straddles the restart point is computed once in phase-1 from
! pure timestep samples (the startup sample lives in the *first*
! window of phase-1, far away) and once in phase-2 with an extra
! sample(restart_time) injected on top of the same timestep samples.
! Result: phase-2's record for that window differs from phase-1's
! by ~1/N (e.g. ~2% with daily output and 30-min coupling).
! That's the source of the ~1e-4 RMS difference seen in the ERS
! cprnc summary before this flag was set.
!
! Disabling compute_on_startup makes both phases skip that initial
! sample. Cost: the very first averaged record of a cold run loses
! one sample out of ~N (e.g. day-1 has 48 samples instead of 49 for
! daily/30-min). All subsequent records are unaffected. For a
! 100-yr SamudrACE tape that's 1 mildly-biased record out of
! ~36500. The startup sample carries no special information
! anyway (it's just the model's IC, which already lives in the
! restart files).
config_AM_fmeDepthCoarsening_compute_on_startup = .false.
config_AM_fmeDepthCoarsening_time_averaging = .true.
! Samudra training spec (Confluence p3ai/6154289880, "case run options for
! v3 LR piControl SamudrACE") requires BOTH 1D-avg AND 1D-instant for the
! four 3D ocean state vars (temperature, salinity, velocityZonal,
! velocityMeridional). DO NOT turn this off without re-checking the spec
! with the SamudrACE team -- ~900 GB savings over a 100-yr run is real but
! the cost of regenerating a non-conforming tape is much higher.
config_AM_fmeDepthCoarsening_write_instantaneous_companion = .true.
config_AM_fmeDepthCoarsening_stream_output_interval = '${FME_MPAS_INTERVAL}'
! 19 depth layers matching ACE ocean interface levels
config_AM_fmeDepthCoarsening_depth_bounds = '0,20,30,40,50,80,110,140,170,230,410,530,1020,1080,1720,1980,2820,3380,4620,6380'
config_AM_fmeDepthCoarsening_fields = 'temperature,salinity,velocityZonal,velocityMeridional'

config_AM_fmeDerivedFields_enable = .true.
config_AM_fmeDerivedFields_compute_interval = 'dt'
config_AM_fmeDerivedFields_compute_on_startup = .false.
config_AM_fmeDerivedFields_time_averaging = .true.
config_AM_fmeDerivedFields_stream_output_interval = '${FME_MPAS_INTERVAL}'

! fmeVerticalReduce disabled: oceanHeatContent / freshwaterContent /
! kineticEnergy are not requested by SamudrACE (Confluence p3ai/6154289880).
config_AM_fmeVerticalReduce_enable = .false.

! Disable non-FME analysis members. The SamudrACE training tape only
! consumes the fmeDepthCoarsening + fmeDerivedFields remapped files;
! globalStats and the timeSeriesStats* AMs are pure storage overhead
! for this configuration. Disabling them also keeps the ERS restart
! comparison clean (timeSeriesStatsDaily isn't BFB across restart in
! this branch — separate issue, not blocking FME).
config_AM_globalStats_enable               = .false.
config_AM_timeSeriesStatsMonthly_enable    = .false.
config_AM_timeSeriesStatsMonthlyMin_enable = .false.
config_AM_timeSeriesStatsMonthlyMax_enable = .false.
EOF

cat >> user_nl_mpaso << EOF
config_AM_fmeDepthCoarsening_output_stream = 'none'
config_AM_fmeDepthCoarsening_horiz_remap_file = '${OCN_MAP}'
config_AM_fmeDerivedFields_output_stream = 'none'
config_AM_fmeDerivedFields_horiz_remap_file = '${OCN_MAP}'
! Native streams are gated to output_interval="none" in buildnml so only
! the .remapped.nc files are produced for the SamudrACE training tape.
config_AM_fmeDepthCoarsening_write_on_startup = .false.
config_AM_fmeDerivedFields_write_on_startup = .false.
EOF

# ---------------------------------------------------------------------------
# MPAS-SeaIce namelist
# ---------------------------------------------------------------------------
cat >> user_nl_mpassi << EOF
!----------------------------------------------------------------------------------
! FME online output -- MPAS-Sea-Ice
!
! ACE needs: iceAreaTotal (ocean_sea_ice_fraction), iceVolumeTotal (sea_ice_volume).
!----------------------------------------------------------------------------------

config_AM_fmeSeaiceDerivedFields_enable = .true.
config_AM_fmeSeaiceDerivedFields_compute_interval = 'dt'
config_AM_fmeSeaiceDerivedFields_compute_on_startup = .false.
config_AM_fmeSeaiceDerivedFields_time_averaging = .true.
config_AM_fmeSeaiceDerivedFields_stream_output_interval = '${FME_MPAS_INTERVAL}'

! Disable non-FME sea-ice analysis members (storage overhead only;
! see comment in user_nl_mpaso block above).
config_AM_regionalStatistics_enable     = .false.
config_AM_timeSeriesStatsDaily_enable   = .false.
config_AM_timeSeriesStatsMonthly_enable = .false.
EOF

cat >> user_nl_mpassi << EOF
config_AM_fmeSeaiceDerivedFields_output_stream = 'none'
config_AM_fmeSeaiceDerivedFields_horiz_remap_file = '${OCN_MAP}'
EOF
