<?xml version="1.0"?>

<?xml-stylesheet type="text/xsl" href="entry_id.xsl" ?>

<entry_id version="3.0">
  <description>
    <desc atm="EATM">Emulator atm component</desc>
  </description>

  <entry id="COMP_ATM">
    <type>char</type>
    <valid_values>eatm</valid_values>
    <default_value>eatm</default_value>
    <group>case_comp</group>
    <file>env_case.xml</file>
    <desc>Name of atmosphere component</desc>
  </entry>

  <entry id="EATM_NXG">
    <type>integer</type>
    <default_value>48</default_value>
    <group>build_component_eatm</group>
    <file>env_build.xml</file>
    <desc>Number of longitude points for the emulator ATM synthetic grid</desc>
  </entry>

  <entry id="EATM_NYG">
    <type>integer</type>
    <default_value>24</default_value>
    <group>build_component_eatm</group>
    <file>env_build.xml</file>
    <desc>Number of latitude points for the emulator ATM synthetic grid</desc>
  </entry>

  <help>
    =========================================
    EATM naming conventions in compset name
    =========================================
  </help>

</entry_id>
