<?xml version="1.0"?>

<definitions_variables>

  <entry id="COMP_ATM">
     <type>char</type>
     <valid_values>emulatoratm</valid_values>
     <default_value>emulatoratm</default_value>
     <group>case_comp</group>
     <file>env_case.xml</file>
     <desc>Name of atm component</desc>
  </entry>

  <entry id="EMULATORATM_MODE">
    <type>char</type>
    <valid_values>ACTIVE,NULL</valid_values>
    <default_value>ACTIVE</default_value>
    <values>
      <value compset="_EMULATORATM.*">ACTIVE</value>
      <value grid="a%null">NULL</value>
    </values>
    <group>build_component_emulatoratm</group>
    <file>env_build.xml</file>
    <desc>mode for emulatoratm model, NULL means emulatoratm is turned off</desc>
  </entry>

  <description>
    <desc compset="_EMULATORATM">EMULATORATM:</desc>
  </description>

  <help>
    =========================================
    EMULATORATM naming conventions
    =========================================
  </help>

</definitions_variables>
